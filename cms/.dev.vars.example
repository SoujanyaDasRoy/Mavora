# Local secrets for `wrangler dev` / `next dev` (via initOpenNextCloudflareForDev).
# Copy to `.dev.vars` (gitignored) and fill in real values for local development.
# D1 (DB) and R2 (MEDIA_BUCKET) are configured as bindings in wrangler.toml, not
# here -- this file is for secret values (API tokens, auth secrets, etc.) that
# later tasks in the CMS build will introduce. No secrets are required by Task 1.

# Clerk (Task 2) -- create a free Clerk application at https://dashboard.clerk.com
# and copy its API keys here. Required for `next dev` to render <ClerkProvider>/
# <SignIn> and for `clerkMiddleware()` in middleware.ts to resolve a key at all
# (it throws if neither is set, even for unauthenticated/pass-through requests).
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# GitHub (Task 12) -- fine-grained Personal Access Token scoped to the
# `Mavora` repo only, with `Contents: Read and write` permission and no other
# permissions. Used by cms/lib/github.ts to commit/delete published articles'
# MDX files directly to the public site's content/posts/ directory via the
# GitHub Contents API. Create this yourself at
# https://github.com/settings/personal-access-tokens/new -- it cannot be
# generated by an agent. Add the real value to your local `.dev.vars` (never
# commit it) and, for production, set it as a Cloudflare Worker secret (this
# app deploys via `opennextjs-cloudflare deploy`/`wrangler deploy` as a
# Worker, not Cloudflare Pages): `wrangler secret put GITHUB_CONTENT_TOKEN`.
GITHUB_CONTENT_TOKEN=github_pat_replace_me_scoped_to_contents_write_only

# Buttondown (Task 15) -- reuses the Buttondown account already created for
# the public site's newsletter signup. Used by cms/lib/stats.ts to fetch the
# subscriber count for the Dashboard. Create/find the API key at
# https://buttondown.com/settings/api -- manual, one-time human step.
BUTTONDOWN_API_KEY=replace_me

# Cloudflare Web Analytics (Task 15) -- used by cms/lib/stats.ts to fetch
# 30-day page view totals for the Dashboard via the Cloudflare GraphQL
# Analytics API. CLOUDFLARE_ANALYTICS_API_TOKEN is an API token scoped to
# Account -> Analytics -> Read, created at
# https://dash.cloudflare.com/profile/api-tokens. CLOUDFLARE_ZONE_TAG is the
# Zone ID for mavora.com, found on the zone's Overview page in the Cloudflare
# dashboard. Both are manual, one-time human steps.
CLOUDFLARE_ANALYTICS_API_TOKEN=replace_me
CLOUDFLARE_ZONE_TAG=replace_me

# CSRF origin check (Task 16) -- middleware.ts rejects mutating (non-GET/HEAD/
# OPTIONS) requests to /api/* whose `Origin` header doesn't exactly match this
# value. Set to the CMS app's own origin: http://localhost:3000 for local
# `next dev`, and the real production origin (e.g.
# https://cms.mavora.com) in Cloudflare's environment variables for the
# deployed Worker.
CMS_ORIGIN=http://localhost:3000

# Public media base URL (whole-branch review, Finding 2) -- MEDIA_BUCKET (R2)
# has no public HTTP access of its own; R2 objects are only reachable by URL
# once the bucket is explicitly connected to a public domain. Uploaded
# images' URLs (cover image and inline BlockNote images, see
# lib/media-client.ts's getPublicMediaUrl) are built by joining this value
# with the object's R2 key, and that same URL is what gets committed into
# published MDX/frontmatter -- so it must be reachable by anyone browsing the
# public site (a fully static export with no server of its own, per
# DEPLOY.md), not just from inside the CMS.
#
# This is a manual, one-time Cloudflare-dashboard step, not something an
# agent can generate: either enable the free `<bucket>.r2.dev` subdomain for
# `mavora-cms-media` (Cloudflare dashboard -> R2 -> mavora-cms-media ->
# Settings -> Public access), or bind a custom domain (e.g.
# media.mavora.com) to the bucket. Set this to that resulting base URL, with
# no trailing slash. Because this is a `NEXT_PUBLIC_` variable, Next.js
# inlines it into the client bundle at BUILD time -- it must be set before
# running `npm run build` / `opennextjs-cloudflare build`, not only as a
# runtime Worker secret.
NEXT_PUBLIC_MEDIA_BASE_URL=https://replace-me.r2.dev
